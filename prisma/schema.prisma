// =============================================================================
// HunarHub — Prisma Schema
// =============================================================================
// This schema models a peer-to-peer skill-matching platform where students
// teach and learn from each other. Relations are designed for:
//   • Many-to-many User ↔ Skill via UserSkill (with role: teach vs learn)
//   • Real-time-style messaging via Conversation + Message
//   • OAuth sessions via NextAuth.js adapter models (Account, Session, etc.)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// SkillType — discriminates how a user relates to a skill on the join table.
// CAN_TEACH: user offers peer tutoring in this skill.
// WANTS_TO_LEARN: user is looking for a peer teacher for this skill.
// -----------------------------------------------------------------------------
enum SkillType {
  CAN_TEACH
  WANTS_TO_LEARN
}

// -----------------------------------------------------------------------------
// User — core identity for students on the platform.
// `university` being null signals incomplete onboarding (see middleware).
// `image` is required by @auth/prisma-adapter; `avatar` mirrors it for the app.
// `totalRating` aggregates peer feedback (updated by future rating features).
// -----------------------------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  university    String?
  avatar        String?
  bio           String?   @db.Text
  totalRating   Float     @default(0)

  accounts   Account[]
  sessions   Session[]
  userSkills UserSkill[]
  messages   Message[]   @relation("MessageSender")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([university])
  @@index([totalRating])
}

// -----------------------------------------------------------------------------
// Skill — canonical skill catalog (e.g. "React", "Calculus").
// Normalized so multiple users reference the same skill row for matching.
// -----------------------------------------------------------------------------
model Skill {
  id       String @id @default(cuid())
  name     String @unique
  category String

  userSkills UserSkill[]

  @@index([category])
}

// -----------------------------------------------------------------------------
// UserSkill — join table (User ↔ Skill) with a typed edge.
// A user can both CAN_TEACH and WANTS_TO_LEARN the same skill (different rows).
// @@unique prevents duplicate rows for the same user/skill/type combination.
// -----------------------------------------------------------------------------
model UserSkill {
  id        String    @id @default(cuid())
  userId    String
  skillId   String
  skillType SkillType

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, skillId, skillType])
  @@index([userId])
  @@index([skillId])
  @@index([skillType])
}

// -----------------------------------------------------------------------------
// ConversationStatus — lifecycle of a skill-exchange request thread.
// PENDING: initial request sent, awaiting accept/decline from the other peer.
// ACTIVE: accepted — both users can chat freely.
// DECLINED: receiver declined the request.
// -----------------------------------------------------------------------------
enum ConversationStatus {
  PENDING
  ACTIVE
  DECLINED
}

// -----------------------------------------------------------------------------
// Conversation — thread between two or more participants.
// `participantIds` is a PostgreSQL text[] for fast membership checks.
// `initiatedById` is the user who clicked "Send Request".
// -----------------------------------------------------------------------------
model Conversation {
  id             String             @id @default(cuid())
  participantIds String[]
  status         ConversationStatus @default(PENDING)
  initiatedById  String?

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// -----------------------------------------------------------------------------
// Message — individual chat message within a conversation.
// `isRequestMode` flags skill-exchange / session-request messages vs normal chat.
// -----------------------------------------------------------------------------
model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  isRequestMode  Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

// =============================================================================
// NextAuth.js / Auth.js adapter models
// Required for OAuth (Google) + database-backed sessions with PrismaAdapter.
// =============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
